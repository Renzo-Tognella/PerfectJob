# PerfectJob Environment Variables
# Copy this file to .env and update the values as needed
# NEVER commit .env with real secrets

# Database
DB_URL=jdbc:postgresql://localhost:5432/perfectjob
DB_USER=perfectjob
DB_PASSWORD=devpass

# JWT Secret - MUST be at least 32 characters and changed in production!
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-this-is-a-temporary-dev-secret-key

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# API URL (used by mobile and admin)
# Para testar em CELULAR FISICO, troque "localhost" pelo IP da sua maquina na rede
# (ex: http://192.168.0.10:8080/api). O ./start.sh detecta e configura isso sozinho.
API_URL=http://localhost:8080/api

# Resume generation — LLM provider (OpenRouter is OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Resume generation — Tectonic LaTeX engine
TECTONIC_PATH=/usr/local/bin/tectonic
PERFECTJOB_RESUME_STORAGE_DIR=data/resumes
